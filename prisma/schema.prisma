// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Products — Performance Mirror of Lightspeed
// ─────────────────────────────────────────────
model Product {
  id              String   @id @default(cuid())
  sku             String   @unique
  title           String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  quantity        Int      @default(0)
  category        String?
  imageUrl        String?  @map("image_url")
  metadata        Json?
  lightspeedId    String?  @unique @map("lightspeed_id")
  woocommerceId   Int?     @unique @map("woocommerce_id")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("products")
}

// ─────────────────────────────────────────────
// Credentials — Encrypted OAuth Token Storage
// ─────────────────────────────────────────────
model Credential {
  id            String   @id @default(cuid())
  platform      String   @unique  // "lightspeed" | "woocommerce"
  accessToken   String   @map("access_token")
  refreshToken  String?  @map("refresh_token")
  expiresAt     DateTime? @map("expires_at")
  accountId     String?  @map("account_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("credentials")
}

// ─────────────────────────────────────────────
// Sync Logs — Audit Trail for Cross-Platform Updates
// ─────────────────────────────────────────────
model SyncLog {
  id          String   @id @default(cuid())
  direction   String   // "ls_to_woo" | "woo_to_ls" | "site_to_ls"
  entityType  String   @map("entity_type")  // "product" | "order" | "sale"
  entityId    String   @map("entity_id")
  status      String   @default("pending")  // "pending" | "success" | "failed"
  payload     Json?
  error       String?
  createdAt   DateTime @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  @@index([direction, status])
  @@index([entityType, entityId])
  @@map("sync_logs")
}
