# ─── Server ─────────────────────────────────
PORT=8080
NODE_ENV=development

# ─── Cloud SQL (PostgreSQL via Prisma) ──────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/lswoo?schema=public

# ─── Memorystore (Redis) ───────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_SYNC_TTL=60

# ─── GCP ───────────────────────────────────
GCP_PROJECT_ID=senmizu
CLOUD_TASKS_LOCATION=us-central1
CLOUD_TASKS_QUEUE=inventory-sync-queue
WORKER_SERVICE_URL=https://lswoo-worker-XXXXX.a.run.app

# ─── Lightspeed Retail OAuth ───────────────
LS_CLIENT_ID=
LS_CLIENT_SECRET=
LS_REDIRECT_URI=https://YOUR_DOMAIN/auth/lightspeed/callback
LS_ACCOUNT_ID=

# ─── WooCommerce REST API ─────────────────
WOO_BASE_URL=https://your-store.com
WOO_CONSUMER_KEY=ck_XXXXX
WOO_CONSUMER_SECRET=cs_XXXXX

# ─── Custom Frontend ──────────────────────
FRONTEND_ORIGIN=http://localhost:3000
